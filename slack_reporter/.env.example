# ── Packrs Courier DMS Credentials ─────────────────────────────
DMS_BASE_URL=https://dms.packrscourier.com.np/dmsadmin
DMS_USERNAME=your_dms_username
DMS_PASSWORD=your_dms_password

# ── Slack Configuration ────────────────────────────────────────
# Webhook URL (required) — for summary messages
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxxx

# Bot Token + Channel ID (optional) — for PDF file uploads
# To get a bot token:
#   1. Go to https://api.slack.com/apps → Your App
#   2. OAuth & Permissions → Bot Token Scopes → add 'files:write'
#   3. Install to Workspace → Copy Bot User OAuth Token
# Channel ID: right-click channel name → "View channel details" → copy ID
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL_ID=C07XXXXXXXX

# ── Schedule ───────────────────────────────────────────────────
REPORT_INTERVAL_HOURS=2
