# Copy this file to `.env` and fill in real values.
# `.env` is gitignored so secrets stay out of version control.

# Slack incoming webhook (GLOBAL fallback).
# Used by src/lib/slack.ts when a company doesn't have its own
# slack_webhook_url set in Settings → General.
# Create one at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=""
